<UserControl x:Class="FPSBoostPro.Views.GamingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="700">

            <TextBlock Text="🎮 Advanced Gaming Tweaks" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>

            <TextBlock Text="Cochez uniquement les optimisations que vous souhaitez appliquer." 
                       FontSize="16" 
                       Foreground="#9CA3AF" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,25"/>

            <!-- Liste des choix avec explications -->
            <Border Background="#1F2937" CornerRadius="10" Padding="20" Margin="0,0,0,25">
                <StackPanel>

                    <!-- Option 1 : Game Mode -->
                    <CheckBox IsChecked="{Binding ApplyGameMode}" Margin="0,0,0,15">
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Activer le Game Mode Windows" FontWeight="Bold" Foreground="White" FontSize="14"/>
                            <TextBlock Text="Force Windows à prioriser le CPU/GPU pour le jeu actif." Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </CheckBox>

                    <!-- Option 2 : Game DVR -->
                    <CheckBox IsChecked="{Binding ApplyDisableDVR}" Margin="0,0,0,15">
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Désactiver le Game DVR" FontWeight="Bold" Foreground="White" FontSize="14"/>
                            <TextBlock Text="Coupe l'enregistrement de clips en arrière-plan (gagne du CPU)." Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </CheckBox>

                    <!-- Option 3 : Souris -->
                    <CheckBox IsChecked="{Binding ApplyMouseTweak}" Margin="0,0,0,15">
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Désactiver l'accélération de la souris" FontWeight="Bold" Foreground="White" FontSize="14"/>
                            <TextBlock Text="Désactive la 'Précision du pointeur' pour une visée brute et constante en jeu." Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </CheckBox>

                    <!-- Option 4 : TRIM SSD -->
                    <CheckBox IsChecked="{Binding ApplyTrim}" Margin="0,0,0,15">
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Optimiser le SSD (TRIM)" FontWeight="Bold" Foreground="White" FontSize="14"/>
                            <TextBlock Text="Force la commande TRIM sur le disque C pour de meilleures performances d'écriture." Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </CheckBox>

                    <!-- Option 5 : Hibernation -->
                    <CheckBox IsChecked="{Binding ApplyDisableHibernation}">
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Désactiver la veille prolongée (Hibernation)" FontWeight="Bold" Foreground="White" FontSize="14"/>
                            <TextBlock Text="Supprime le fichier 'hiberfil.sys' pour libérer instantanément plusieurs Go sur le disque." Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </CheckBox>

                </StackPanel>
            </Border>

            <Button Content="Appliquer la sélection" 
                    Width="300" 
                    Height="50"
                    Command="{Binding OptimizeGamingCommand}"/>

            <TextBlock Text="{Binding GamingStatus}" 
                       FontSize="16" 
                       FontWeight="SemiBold"
                       Foreground="#EC4899" 
                       HorizontalAlignment="Center" 
                       Margin="0,20,0,0"/>

        </StackPanel>
    </Grid>
</UserControl>