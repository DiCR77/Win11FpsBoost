<UserControl x:Class="FPSBoostPro.Views.GamingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="30,20,30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10,0,0,20">
            <TextBlock Text="G A M I N G" FontFamily="Segoe UI Semibold" FontSize="11" FontWeight="Bold" Foreground="#8B5CF6"/>
            <TextBlock Text="Optimisations Jeux" FontFamily="Segoe UI Light" FontSize="36" Foreground="White"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="10,0,10,15">
            <CheckBox Content="Activer le Mode Jeu" IsChecked="{Binding ApplyGameMode}" Foreground="White" Margin="0,5"/>
            <CheckBox Content="Désactiver Game DVR (Recommandé)" IsChecked="{Binding ApplyDisableDVR}" Foreground="White" Margin="0,5"/>
            <CheckBox Content="Désactiver l'accélération souris" IsChecked="{Binding ApplyMouseTweak}" Foreground="White" Margin="0,5"/>
            <CheckBox Content="TRIM SSD (Améliore la lecture)" IsChecked="{Binding ApplyTrim}" Foreground="White" Margin="0,5"/>
            <CheckBox Content="Désactiver l'Hibernation" IsChecked="{Binding ApplyDisableHibernation}" Foreground="White" Margin="0,5"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="10,0,10,20">
            <TextBlock Text="ℹ️ Les options cochées modifieront le Registre Windows. Un redémarrage sera nécessaire." 
                       Foreground="#9CA3AF" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,15"/>

            <Button Content="Appliquer les optimisations" Command="{Binding OptimizeGamingCommand}" Width="280" Height="48" BorderThickness="0" Cursor="Hand" Background="#8B5CF6" HorizontalAlignment="Left"/>
            <TextBlock Text="{Binding GamingStatus}" FontFamily="Segoe UI Semibold" FontSize="15" Foreground="#10B981" Margin="0,15,0,0"/>
        </StackPanel>

        <Border Grid.Row="3" Background="#111827" CornerRadius="12" BorderBrush="#374151" BorderThickness="1" Margin="10,0,10,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="15">
                <TextBlock Text="{Binding AuditLog}" FontFamily="Consolas" FontSize="14" Foreground="#D1D5DB" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>