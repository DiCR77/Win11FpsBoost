<UserControl x:Class="FPSBoostPro.Views.GamingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="OptionRow" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#242836"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OptionCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.15" ScaleY="1.15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type RepeatButton}" x:Key="ScrollBarButton">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Thumb}" x:Key="ScrollBarThumb">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Rectangle Fill="#8B5CF6" RadiusX="4" RadiusY="4" Width="8"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid>
                            <Border Background="Transparent" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarButton}" Command="{x:Static ScrollBar.PageUpCommand}" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarButton}" Command="{x:Static ScrollBar.PageDownCommand}" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30,20,30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10,0,0,20">
            <TextBlock Text="G A M I N G" FontFamily="Segoe UI Semibold" FontSize="11" FontWeight="Bold" Foreground="#8B5CF6"/>
            <TextBlock Text="Optimisations Jeux" FontFamily="Segoe UI Light" FontSize="36" Foreground="White"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#171A23" CornerRadius="12" BorderBrush="#2A2E3A" BorderThickness="1" Padding="6" Margin="10,0,10,15">
            <StackPanel>
                <Border Style="{StaticResource OptionRow}">
                    <CheckBox Content="Activer le Mode Jeu" IsChecked="{Binding ApplyGameMode}" Style="{StaticResource OptionCheckBox}"/>
                </Border>
                <Border Style="{StaticResource OptionRow}">
                    <CheckBox IsChecked="{Binding ApplyDisableDVR}" Style="{StaticResource OptionCheckBox}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Désactiver Game DVR" VerticalAlignment="Center"/>
                            <Border Background="#10B98122" CornerRadius="8" Padding="6,2" Margin="8,0,0,0">
                                <TextBlock Text="Recommandé" FontSize="10" FontFamily="Segoe UI Semibold" Foreground="#10B981"/>
                            </Border>
                        </StackPanel>
                    </CheckBox>
                </Border>
                <Border Style="{StaticResource OptionRow}">
                    <CheckBox Content="Désactiver l'accélération souris" IsChecked="{Binding ApplyMouseTweak}" Style="{StaticResource OptionCheckBox}"/>
                </Border>
                <Border Style="{StaticResource OptionRow}">
                    <CheckBox Content="TRIM SSD (améliore la lecture)" IsChecked="{Binding ApplyTrim}" Style="{StaticResource OptionCheckBox}"/>
                </Border>
                <Border Style="{StaticResource OptionRow}">
                    <CheckBox Content="Désactiver l'Hibernation" IsChecked="{Binding ApplyDisableHibernation}" Style="{StaticResource OptionCheckBox}"/>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#1B1E29" CornerRadius="10" Padding="14,12" Margin="10,0,10,20" BorderBrush="#2A2E3A" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="20" Height="20" CornerRadius="10" Background="#8B5CF633" VerticalAlignment="Top">
                    <TextBlock Text="i" FontFamily="Georgia" FontStyle="Italic" FontWeight="Bold" FontSize="13" Foreground="#A78BFA" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="Les options cochées modifieront le Registre Windows. Un redémarrage sera nécessaire." Foreground="#9CA3AF" FontSize="13" TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Margin="10,0,10,20">
            <Button Content="Appliquer les optimisations" Command="{Binding OptimizeGamingCommand}" Width="280" Height="48" BorderThickness="0" Cursor="Hand" Background="#8B5CF6" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="14" HorizontalAlignment="Left"/>
            <TextBlock Text="{Binding GamingStatus}" FontFamily="Segoe UI Semibold" FontSize="15" Foreground="#10B981" Margin="0,15,0,0"/>
        </StackPanel>

        <Border Grid.Row="4" Background="#111827" CornerRadius="12" BorderBrush="#2A2E3A" BorderThickness="1" Margin="10,0,10,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="#2A2E3A" BorderThickness="0,0,0,1" Padding="14,10">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Fill="#EF4444" Margin="0,0,5,0"/>
                        <Ellipse Width="9" Height="9" Fill="#F59E0B" Margin="0,0,5,0"/>
                        <Ellipse Width="9" Height="9" Fill="#10B981" Margin="0,0,10,0"/>
                        <TextBlock Text="Journal d'activité" FontFamily="Consolas" FontSize="12" Foreground="#6B7280"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="15" Background="Transparent">
                    <TextBlock Text="{Binding AuditLog}" FontFamily="Consolas" FontSize="14" Foreground="#D1D5DB" TextWrapping="Wrap" Background="Transparent"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>