<Window x:Class="FPSBoostPro.Views.MainWindow"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:FPSBoostPro.ViewModels"
        xmlns:views="clr-namespace:FPSBoostPro.Views"
        Title="DIBoost FPS"
        Height="700"
        Width="1150"
        WindowStartupLocation="CenterScreen"
        Background="#111827">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:ServicesViewModel}">
            <views:ServicesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:NetworkViewModel}">
            <views:NetworkView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type views:DashboardView}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:OneClickViewModel}">
            <views:OneClickView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:PowerViewModel}">
            <views:PowerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:GamingViewModel}">
            <views:GamingView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>

        <!-- Style local pour les boutons de la sidebar : mêmes triggers hover/pressed
             que ton style Button d'origine, juste avec le contenu aligné à gauche
             et un peu plus de place pour respirer -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Foreground" Value="#D1D5DB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter Margin="16,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#4F46E5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#312E81"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#111827">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==================== SIDEBAR ==================== -->
        <Border Background="#1A1D27">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,26,20,26">
                    <Image Source="vlogo.ico" Width="32" Height="32" Margin="0,0,10,0"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="DIBoost FPS" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Foreground="White"/>
                        <TextBlock Text="Optimisation Windows" 
                   FontSize="11" 
                   Foreground="#6B7280"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation : occupe tout l'espace disponible, fond de carte pour ne pas laisser de vide -->
                <Border Grid.Row="1" Background="#171A23" CornerRadius="14" Margin="14,0,14,14">
                    <StackPanel Margin="10,16,10,16">

                        <Button Style="{StaticResource NavButton}"
                Command="{Binding NavigateCommand}"
                CommandParameter="Dashboard" Click="Button_Click">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="🏠" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                <TextBlock Text="Tableau de bord" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButton}"
                Command="{Binding NavigateCommand}"
                CommandParameter="OneClick">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="🚀" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                <TextBlock Text="Boost en un clic" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButton}"
                Command="{Binding NavigateCommand}"
                CommandParameter="Network">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="🌐" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                <TextBlock Text="Réseau" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButton}"
                Command="{Binding NavigateCommand}"
                CommandParameter="Services">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="⚙️" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                <TextBlock Text="Services" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButton}"
                Command="{Binding NavigateCommand}"
                CommandParameter="Power">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="🔋" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                <TextBlock Text="Alimentation" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButton}"
                Command="{Binding NavigateCommand}"
                CommandParameter="Gaming">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="🎮" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                <TextBlock Text="Optimisations Gaming" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Border>

                <!-- ==================== FOOTER DÉVELOPPEUR ==================== -->
                <StackPanel Grid.Row="2" Margin="20,0,20,20">
                    <Border BorderBrush="#262A36" BorderThickness="0,1,0,0" Margin="0,0,0,14"/>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#4F46E5">
                            <TextBlock Text="D" FontFamily="Segoe UI Semibold" FontSize="13" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Diae" FontFamily="Segoe UI Semibold" FontSize="13" Foreground="#E5E7EB"/>
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/DiCR77"
                                           Foreground="#6B7280"
                                           FontSize="11"
                                           RequestNavigate="Hyperlink_RequestNavigate">
                                    github.com/DiCR77
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== CONTENU ==================== -->
        <Grid Grid.Column="1" Background="#111827" Margin="30">
            <ContentControl Content="{Binding CurrentView}"/>
        </Grid>

    </Grid>
</Window>
