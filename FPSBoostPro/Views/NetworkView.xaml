<UserControl x:Class="FPSBoostPro.Views.NetworkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="30,20,30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10,0,0,30">
            <TextBlock Text="O P T I M I S A T I O N   P I N G" FontFamily="Segoe UI Semibold" FontSize="11" FontWeight="Bold" Foreground="#10B981"/>
            <TextBlock Text="Optimisations Réseau" FontFamily="Segoe UI Light" FontSize="36" Foreground="White" Margin="0,5,0,0"/>
            <TextBlock Text="Ajustements du réseau Windows pour réduire la latence en jeu." FontFamily="Segoe UI" Foreground="#9CA3AF" FontSize="13" Margin="0,5,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Background="#1F2937" CornerRadius="16" Padding="25" BorderBrush="#374151" BorderThickness="1" VerticalAlignment="Top">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                    <StackPanel>
                        <TextBlock Text="Modifications réseau appliquées :" FontFamily="Segoe UI Semibold" FontSize="18" Foreground="White" Margin="0,0,0,20"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <TextBlock Text="🌐" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Top"/>
                            <StackPanel>
                                <TextBlock Text="Désactiver le Network Throttling Index" FontFamily="Segoe UI Semibold" Foreground="#D1D5DB" FontSize="14"/>
                                <TextBlock Text="Empêche Windows de brider le réseau non-multimédia pendant que vous jouez." FontFamily="Segoe UI" Foreground="#9CA3AF" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <TextBlock Text="⚡" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Top"/>
                            <StackPanel>
                                <TextBlock Text="Traitement optimisé des paquets (TcpNoDelay &amp; Auto-Tuning)" FontFamily="Segoe UI Semibold" Foreground="#D1D5DB" FontSize="14"/>
                                <TextBlock Text="Élimine le délai d'attente de cumul des paquets TCP et ajuste la fenêtre de réception réseau." FontFamily="Segoe UI" Foreground="#9CA3AF" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <TextBlock Text="🧹" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Top"/>
                            <StackPanel>
                                <TextBlock Text="Vidage du cache (Flush DNS) &amp; Reset Winsock" FontFamily="Segoe UI Semibold" Foreground="#D1D5DB" FontSize="14"/>
                                <TextBlock Text="Nettoie les tables d'adresses corrompues et réinitialise la pile réseau pour éviter les pertes de paquets." FontFamily="Segoe UI" Foreground="#9CA3AF" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,20,0,0" HorizontalAlignment="Center">
                <Button Content="Optimiser le Ping (Registry &amp; Commands)" Command="{Binding OptimizeNetworkCommand}" Width="320" Height="48" BorderThickness="0" Cursor="Hand" Background="#10B981"/>
                <TextBlock Text="{Binding NetworkStatus}" FontFamily="Segoe UI Semibold" FontSize="15" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>