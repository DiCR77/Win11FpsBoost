<UserControl x:Class="FPSBoostPro.Views.OneClickView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="30,20,30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10,0,0,30">
            <TextBlock Text="N E T T O Y A G E   R A P I D E" FontFamily="Segoe UI Semibold" FontSize="11" FontWeight="Bold" Foreground="#8B5CF6"/>
            <TextBlock Text="Boost en un clic" FontFamily="Segoe UI Light" FontSize="36" Foreground="White" Margin="0,5,0,0"/>
            <TextBlock Text="Suppression sécurisée des caches et fichiers temporaires système." FontFamily="Segoe UI" Foreground="#9CA3AF" FontSize="13" Margin="0,5,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Background="#1F2937" CornerRadius="16" Padding="25" BorderBrush="#374151" BorderThickness="1" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Actions effectuées d'un clic :" FontFamily="Segoe UI Semibold" FontSize="18" Foreground="White" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="🛡" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Création automatique d'un point de restauration système" FontFamily="Segoe UI" Foreground="#10B981" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="🧹" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Vider le dossier temporaire utilisateur (%TEMP%)" FontFamily="Segoe UI" Foreground="#D1D5DB" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="💾" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Purge des fichiers caches de Windows" FontFamily="Segoe UI" Foreground="#D1D5DB" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="🧠" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Forcer la libération de la mémoire RAM inutile" FontFamily="Segoe UI" Foreground="#D1D5DB" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="#111827" CornerRadius="8" Padding="12" Margin="0,20,0,0">
                        <TextBlock Text="⚠ Aucun fichier personnel ou jeu ne sera supprimé lors de cette opération." FontFamily="Segoe UI" Foreground="#F59E0B" FontSize="12" FontStyle="Italic" HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,20,0,0" HorizontalAlignment="Center">
                <Button Content="Lancer l'optimisation" Width="280" Height="48" BorderThickness="0" Cursor="Hand" Background="#8B5CF6"/>
                <TextBlock Text="{Binding StatusMessage}" FontFamily="Segoe UI Semibold" FontSize="15" Foreground="#8B5CF6" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>