<UserControl x:Class="FPSBoostPro.Views.PowerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="30,20,30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10,0,0,30">
            <TextBlock Text="A L I M E N T A T I O N" 
                       FontFamily="Segoe UI Semibold" 
                       FontSize="11" 
                       FontWeight="Bold" 
                       Foreground="#3B82F6"/>

            <TextBlock Text="Power Plan Optimizer" 
                       FontFamily="Segoe UI Light" 
                       FontSize="36" 
                       Foreground="White" 
                       Margin="0,5,0,0"/>

            <TextBlock Text="Ajustement de l'alimentation CPU pour éliminer les économies d'énergie en jeu." 
                       FontFamily="Segoe UI" 
                       Foreground="#9CA3AF" 
                       FontSize="13" 
                       Margin="0,5,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Background="#1F2937" 
                    CornerRadius="16" 
                    Padding="25" 
                    BorderBrush="#374151" 
                    BorderThickness="1" 
                    VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Modifications appliquées :" 
                               FontFamily="Segoe UI Semibold" 
                               FontSize="18" 
                               Foreground="White" 
                               Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" Margin="0,8">
                        <TextBlock Text="🔌" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <StackPanel>
                            <TextBlock Text="Plan 'Performances Optimales' (Ultimate Performance)" 
                                       FontFamily="Segoe UI Semibold" 
                                       Foreground="#D1D5DB" 
                                       FontSize="14"/>
                            <TextBlock Text="Active le profil d'alimentation caché de Windows pour maximiser les fréquences CPU." 
                                       FontFamily="Segoe UI" 
                                       Foreground="#9CA3AF" 
                                       FontSize="12" 
                                       Margin="0,2,0,12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8">
                        <TextBlock Text="🖱" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <StackPanel>
                            <TextBlock Text="Désactiver la suspension sélective USB" 
                                       FontFamily="Segoe UI Semibold" 
                                       Foreground="#D1D5DB" 
                                       FontSize="14"/>
                            <TextBlock Text="Empêche Windows de couper l'alimentation de vos périphériques (souris/casque) pour économiser de l'énergie." 
                                       FontFamily="Segoe UI" 
                                       Foreground="#9CA3AF" 
                                       FontSize="12" 
                                       Margin="0,2,0,12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8">
                        <TextBlock Text="🎮" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <StackPanel>
                            <TextBlock Text="Désactiver l'économie d'énergie PCIe Link State" 
                                       FontFamily="Segoe UI Semibold" 
                                       Foreground="#D1D5DB" 
                                       FontSize="14"/>
                            <TextBlock Text="Force le bus PCIe à rester à sa bande passante maximale pour éviter que le GPU ne s'endorme en veille." 
                                       FontFamily="Segoe UI" 
                                       Foreground="#9CA3AF" 
                                       FontSize="12" 
                                       Margin="0,2,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,20,0,0" HorizontalAlignment="Center">
                <Button Content="Débrider l'Alimentation" 
                        Width="280" 
                        Height="48" 
                        Command="{Binding OptimizePowerCommand}"
                        Cursor="Hand" 
                        Background="#3B82F6"/>

                <TextBlock Text="{Binding PowerStatus}" 
                           FontFamily="Segoe UI Semibold" 
                           FontSize="15" 
                           Foreground="#3B82F6" 
                           HorizontalAlignment="Center" 
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>