<UserControl x:Class="FPSBoostPro.Views.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="30,20,30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10,0,0,20">
            <TextBlock Text="S E R V I C E S" FontFamily="Segoe UI Semibold" FontSize="11" FontWeight="Bold" Foreground="#8B5CF6"/>
            <TextBlock Text="Désactiver les services inutiles" FontFamily="Segoe UI Light" FontSize="36" Foreground="White"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="10,0,10,20">
            <TextBlock Text="ℹ️ Cette action désactive les services Windows gourmands en arrière-plan (Télémétrie, Superfetch, Recherche) pour libérer de la mémoire RAM et du CPU." 
                       Foreground="#9CA3AF" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,15"/>

            <Button Content="Optimiser les services" Command="{Binding DisableServicesCommand}" Width="280" Height="48" BorderThickness="0" Cursor="Hand" Background="#8B5CF6" HorizontalAlignment="Left"/>
            <TextBlock Text="{Binding ServiceStatus}" FontFamily="Segoe UI Semibold" FontSize="15" Foreground="#10B981" Margin="0,15,0,0"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#111827" CornerRadius="12" BorderBrush="#374151" BorderThickness="1" Margin="10,0,10,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="15">
                <TextBlock Text="{Binding AuditLog}" FontFamily="Consolas" FontSize="14" Foreground="#D1D5DB" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>